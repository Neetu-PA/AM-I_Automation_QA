# ============================================
# Environment Configuration
# ============================================
# 
# IMPORTANT: All application settings (URLs, credentials, timeouts)
# are now configured in: config/environments/*.json
#
# This .env file is only for runtime overrides
# ============================================

# Which environment to use (dev, staging, prod)
NODE_ENV=dev

# Browser Configuration
BROWSER=chromium
HEADLESS=false
SLOW_MO=0
DEVTOOLS=false

# Test Configuration
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
ASSERTION_TIMEOUT=5000
PARALLEL_WORKERS=1
RETRY_COUNT=0
RETRY_TAG_FILTER=@flaky

# Feature Flags
ENABLE_MOCKING=false
ENABLE_REPORTING=true
ENABLE_SCREENSHOTS=true
ENABLE_VIDEOS=false

# Reporting Configuration
USE_ALLURE=false
USE_MCP=false
REPORT_PATH=reports/cucumber-report.html

# Cucumber Configuration
CUCUMBER_TAGS=not @ignore
DRY_RUN=false

# Playwright Configuration
PWDEBUG=0
PWVIDEO=0

# CI/CD Configuration
CI=false
GITHUB_REF=
GITHUB_SHA=
TEST_SESSION_ID=

# Authentication (if needed)
API_KEY=
TEST_USERNAME= 
TEST_PASSWORD=
WEBDEALER_BASE_URL=''

# Database Configuration (if needed)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Slack Notifications (if needed)
SLACK_WEBHOOK_URL=

# TestRail Integration (if needed)
TESTRAIL_HOST=
TESTRAIL_USERNAME=
TESTRAIL_PASSWORD=
TESTRAIL_PROJECT_ID=

# Logging Configuration
LOG_LEVEL=info


