{
  "name": "cucumber-playwright",
  "version": "1.2.0",
  "description": "Starter project to write and debug cucumber-js features with Playwright",
  "main": "index.js",
  "scripts": {
    "build": "rimraf build && npm run format && npm run lint && tsc && npm run cucumber-check",
    "cucumber-check": "cucumber-js features/**/*.feature --dry-run",
    "format": "prettier --write \"**/*.{ts,tsx,css,html,json,md}\"",
    "lint": "eslint ./ --ext .js,.ts,.tsx --format visualstudio --no-color --report-unused-disable-directives",
    "lint:fix": "eslint ./ --ext .js,.ts,.tsx --fix",
    "test": "cucumber-js",
    "test:dev": "NODE_ENV=dev cucumber-js",
    "test:staging": "NODE_ENV=staging cucumber-js",
    "test:prod": "NODE_ENV=prod cucumber-js",
    "test:headless": "HEADLESS=true cucumber-js",
    "test:headed": "HEADLESS=false cucumber-js",
    "test:debug": "PWDEBUG=1 DEBUG=pw:api cucumber-js",
    "test:parallel": "PARALLEL_WORKERS=2 cucumber-js",
    "test:retry": "RETRY_COUNT=2 cucumber-js",
    "test:video": "PWVIDEO=1 cucumber-js",
    "test:mcp": "USE_MCP=true cucumber-js",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "test:headfull": "cucumber-js --tags @headfull",
    "test:ci": "NODE_ENV=staging USE_MCP=true HEADLESS=true cucumber-js",
    "playwright:install": "npx playwright install",
    "playwright:install-deps": "npx playwright install-deps",
    "playwright:codegen": "npx playwright codegen",
    "playwright:test": "npx playwright test",
    "report:open": "open reports/cucumber-report.html",
    "snippets": "cucumber-js features/**/*.feature --dry-run --format snippets",
    "steps-usage": "cucumber-js features/**/*.feature --dry-run",
    "clean": "rimraf build reports test-results screenshots",
    "clean:reports": "rimraf reports",
    "clean:screenshots": "rimraf screenshots",
    "setup": "npm install && npm run playwright:install",
    "docker:build": "docker build -t playwright-cucumber .",
    "docker:run": "docker run --rm -v $(pwd):/workspace playwright-cucumber",
    "docker:shell": "docker run --rm --network host -v $(pwd):/work/ -w /work/ -it mcr.microsoft.com/playwright:latest /bin/bash",
    "coverage": "typescript-coverage-report -o reports/coverage-ts",
    "coverage:open": "open reports/coverage-ts/index.html",
    "validate": "npm run lint && npm run cucumber-check && npm run build",
    "precommit": "npm run format && npm run lint:fix && npm run validate"
  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "@cucumber/html-formatter": "21.2.0",
    "@cucumber/messages": "^24.0.1",
    "@playwright/test": "1.41.1",
    "@types/fs-extra": "11.0.4",
    "axios": "^1.13.2",
    "cucumber-console-formatter": "1.0.0",
    "dotenv": "^16.4.1",
    "moment": "^2.30.1",
    "pixelmatch": "5.3.0",
    "playwright-fluent": "^1.61.0",
    "pngjs": "7.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/expect": "24.3.0",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.14.202",
    "@types/node": "^20.11.6",
    "@types/pixelmatch": "5.2.6",
    "@types/pngjs": "6.0.4",
    "@typescript-eslint/eslint-plugin": "6.19.1",
    "@typescript-eslint/parser": "6.19.1",
    "allure-cucumberjs": "2.11.1",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "5.1.3",
    "fs-extra": "11.2.0",
    "open": "10.0.3",
    "prettier": "3.2.4",
    "rimraf": "5.0.5",
    "standard-version": "^9.5.0",
    "typescript": "5.3.3",
    "typescript-coverage-report": "^0.8.0"
  }
}
