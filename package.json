{
  "name": "cucumber-playwright",
  "version": "1.2.0",
  "description": "Starter project to write and debug cucumber-js features with Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:headed": "playwright test --grep @smoke --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:debug": "playwright test --ui",
    "test:report": "playwright show-report playwright-report",
    "bs:test": "browserstack-node-sdk playwright test",
    "bs:smoke": "browserstack-node-sdk playwright test --grep @smoke",
    "bs:regression": "browserstack-node-sdk playwright test --grep @regression",
    "bs:auth": "browserstack-node-sdk playwright test tests/auth.spec.ts",
    "bs:carstock": "browserstack-node-sdk playwright test tests/carstock.spec.ts",
    "bs:all": "npm run bs:test",
    "bs:manual-cdp": "playwright test --config=playwright.bs.config.ts",
    "bs:perf": "browserstack-node-sdk playwright test tests/performance.spec.ts",
    "postinstall": "npm update browserstack-node-sdk"
  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "@cucumber/html-formatter": "21.2.0",
    "@cucumber/messages": "^24.0.1",
    "@playwright/test": "1.41.1",
    "@types/fs-extra": "11.0.4",
    "axios": "^1.13.2",
    "cucumber-console-formatter": "1.0.0",
    "dotenv": "^16.4.1",
    "moment": "^2.30.1",
    "pixelmatch": "5.3.0",
    "playwright-fluent": "^1.61.0",
    "pngjs": "7.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/expect": "24.3.0",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.14.202",
    "@types/node": "^20.11.6",
    "@types/pixelmatch": "5.2.6",
    "@types/pngjs": "6.0.4",
    "@typescript-eslint/eslint-plugin": "6.19.1",
    "@typescript-eslint/parser": "6.19.1",
    "allure-cucumberjs": "2.11.1",
    "browserstack-node-sdk": "^1.50.10",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "5.1.3",
    "fs-extra": "11.2.0",
    "open": "10.0.3",
    "prettier": "3.2.4",
    "rimraf": "5.0.5",
    "standard-version": "^9.5.0",
    "typescript": "5.3.3",
    "typescript-coverage-report": "^0.8.0"
  }
}
